*.class

# NPM package files (created during development)
package.json
package-lock.json

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Intellij files
.idea/
.gradle/
.build/
build/

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*

# Git worktrees
.worktrees/

# Claude local settings
.claude/settings.local.json
.claude/ralph-loop.local.md
CLAUDE.local.md

# Debug output files
*.debug.txt

# Screenshot directory (generated at runtime)
screenshots/

# Doc screenshots (generated at runtime)
doc/screenshots/*.png

# Test screenshots (generated at runtime)
testroms/screenshots/
testroms/fire_debug.txt
testroms/kirby_debug.txt
test-output*.png

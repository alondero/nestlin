*.nes
!testroms/nestest.nes

# 7z archives
*.7z

# Replays
replays/

# Plans
docs/plans/

# Python bytecode cache
__pycache__/

# NES CPU memory dumps (generated by debug sessions)
*.dmp

# Undocumented Opcodes (generated at runtime)
undocumented_opcodes.txt